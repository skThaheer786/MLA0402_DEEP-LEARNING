import numpy as np

# Input values
x = np.array([2, 3])

# Weights
w = np.array([0.5, 0.4])

# Bias
b = 0.2

# Weighted sum
z = np.dot(x, w) + b

# Sigmoid Activation
sigmoid = 1 / (1 + np.exp(-z))

# ReLU Activation
relu = max(0, z)

print("Weighted Sum =", z)
print("Sigmoid Output =", sigmoid)
print("ReLU Output =", relu)
