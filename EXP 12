from sklearn.neural_network import MLPRegressor
from sklearn.datasets import make_regression

# Generate dataset
X, y = make_regression(
    n_samples=500,
    n_features=5,
    random_state=1
)

# Mini-Batch Gradient Descent
model = MLPRegressor(
    hidden_layer_sizes=(10,),
    batch_size=32,
    max_iter=300,
    random_state=1
)

model.fit(X, y)

print("Training Score =", round(model.score(X, y),2))
