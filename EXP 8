import numpy as np

# Input Layer
X = np.array([1, 2])

# Hidden Layer Weights
W1 = np.array([
    [0.1, 0.2],
    [0.3, 0.4]
])

# Hidden Layer Bias
B1 = np.array([0.1, 0.1])

# Hidden Layer Output
hidden = np.dot(X, W1) + B1

# ReLU Activation
hidden = np.maximum(0, hidden)

print("Hidden Layer =", hidden)

# Output Layer Weights
W2 = np.array([
    [0.5],
    [0.6]
])

# Output Layer Bias
B2 = 0.2

# Final Output
output = np.dot(hidden, W2) + B2

print("Final Output =", output)
